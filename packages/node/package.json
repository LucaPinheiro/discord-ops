{
  "name": "discord-ops",
  "version": "0.1.0",
  "description": "Plug-and-play Discord alerts for your SaaS backend. Fire-and-forget, zero-infra, webhook or bot.",
  "keywords": [
    "discord",
    "webhook",
    "alert",
    "notification",
    "monitoring",
    "observability",
    "bot",
    "saas"
  ],
  "author": "Luca Gomes <lucapgomes11@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucapgomes/discord-ops.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/lucapgomes/discord-ops#readme",
  "bugs": {
    "url": "https://github.com/lucapgomes/discord-ops/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
